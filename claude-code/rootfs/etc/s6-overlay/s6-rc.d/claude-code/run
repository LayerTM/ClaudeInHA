#!/command/with-contenv bashio
# ==============================================================================
# claude-code: single longrun service
# Phase 1: initialization (persistent HOME, auth, env, CLAUDE.md)
# Phase 2: exec Node web console (terminal server on the ingress port)
# ==============================================================================

bashio::log.info "Initializing Claude Code add-on..."

# --- Persistent HOME ---
# The Claude binary is installed to /root/.local at build time and copied to
# /data/home/.local so login state, sessions and updates survive restarts.
mkdir -p /data/home
if [ ! -d /data/home/.local ]; then
    bashio::log.info "First run — setting up persistent home directory..."
    cp -a /root/.local /data/home/.local
fi

# Guarantee the persistent binary actually RUNS on this image. /data survives
# add-on updates, so an upgrade that changes the base libc (e.g. the Alpine→
# Debian move: a musl binary left in /data can't run on glibc → "cannot execute:
# required file not found") must re-seed the binary from the current image.
# Preserves ~/.claude (auth/sessions) — only ~/.local (the binary) is replaced.
if ! /data/home/.local/bin/claude --version >/dev/null 2>&1; then
    bashio::log.warning "Persistent Claude binary is missing or incompatible with this image — reinstalling from the image (login/sessions are kept)"
    rm -rf /data/home/.local
    cp -a /root/.local /data/home/.local
fi

export HOME=/data/home
export PATH="/data/home/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export TERM=xterm-256color
export LANG=C.UTF-8
export USE_BUILTIN_RIPGREP=0

# Claude refuses --dangerously-skip-permissions under root unless it detects
# a sandbox; the add-on container is one.
export IS_SANDBOX=1

# --- Sync Claude binary from image if newer ---
# After an add-on image rebuild the bundled Claude may be newer than the
# persistent copy; sync so image upgrades actually deliver the newer binary.
sync_claude_from_image() {
    local image_bin="/root/.local/bin/claude"
    local persistent_bin="/data/home/.local/bin/claude"

    [ -x "${image_bin}" ] || return 0
    [ -x "${persistent_bin}" ] || return 0

    local image_v persistent_v newer
    image_v=$("${image_bin}" --version 2>/dev/null | awk '{print $1}') || image_v=""
    persistent_v=$("${persistent_bin}" --version 2>/dev/null | awk '{print $1}') || persistent_v=""

    if [ -z "${image_v}" ] || [ -z "${persistent_v}" ]; then
        bashio::log.warning "Could not determine Claude version for binary sync"
        return 0
    fi

    if [ "${image_v}" = "${persistent_v}" ]; then
        bashio::log.info "Claude Code version: ${persistent_v}"
        return 0
    fi

    newer=$(printf '%s\n%s\n' "${image_v}" "${persistent_v}" | sort -V | tail -n1)

    if [ "${newer}" = "${image_v}" ]; then
        bashio::log.info "Image has newer Claude (${image_v} > ${persistent_v}) — syncing to persistent storage"
        rm -rf /data/home/.local/share/claude
        mkdir -p /data/home/.local/share
        cp -a /root/.local/share/claude /data/home/.local/share/ 2>/dev/null || true
        cp -af "${image_bin}" "${persistent_bin}"
    else
        bashio::log.info "Persistent Claude (${persistent_v}) is newer than image (${image_v}) — keeping persistent"
    fi
}

sync_claude_from_image

# --- Authentication ---
#   1. ANTHROPIC_API_KEY       — API key from console.anthropic.com
#   2. CLAUDE_CODE_OAUTH_TOKEN — long-lived token from `claude setup-token`
#   3. Interactive /login in the terminal (persists in /data/home/.claude)
api_key=$(bashio::config 'api_key')
oauth_token=$(bashio::config 'oauth_token')

if bashio::var.has_value "${api_key}"; then
    export ANTHROPIC_API_KEY="${api_key}"
    bashio::log.info "Anthropic API key configured"
fi

if bashio::var.has_value "${oauth_token}"; then
    export CLAUDE_CODE_OAUTH_TOKEN="${oauth_token}"
    bashio::log.info "CLAUDE_CODE_OAUTH_TOKEN configured"
fi

if ! bashio::var.has_value "${api_key}" && ! bashio::var.has_value "${oauth_token}"; then
    bashio::log.notice "No api_key or oauth_token set — log in from the Claude tab (run 'claude' and follow the URL) or use a token from 'claude setup-token'"
fi

# --- Home Assistant access token (LLAT) ---
# Persists across add-on updates (stored by the Supervisor). Feeds the browser
# dashboard screenshots, hass-cli, hass-mcp, and direct WS/REST access as the
# user. Exported under the several names those tools expect.
# Read straight from options.json (no Supervisor API dependency).
ha_token=$(jq -r '.ha_token // ""' /data/options.json 2>/dev/null || echo "")
export HA_URL="http://homeassistant:8123"
if [ -n "${ha_token}" ]; then
    export HA_TOKEN="${ha_token}"
    export HASS_TOKEN="${ha_token}"
    export HASS_SERVER="${HA_URL}"
    bashio::log.info "HA Token configured (dashboard screenshots + HA tools enabled)"
fi

# `ha` (Supervisor CLI) reads SUPERVISOR_API_TOKEN, but the runtime injects
# SUPERVISOR_TOKEN — bridge the two so `ha ...` works with zero prep.
if [ -n "${SUPERVISOR_TOKEN:-}" ]; then
    export SUPERVISOR_API_TOKEN="${SUPERVISOR_TOKEN}"
fi

# --- Model override ---
model=$(bashio::config 'model')
if bashio::var.has_value "${model}"; then
    export ANTHROPIC_MODEL="${model}"
    bashio::log.info "Model override: ${model}"
fi

# --- Auto-update on startup ---
if bashio::config.true 'auto_update'; then
    bashio::log.info "Checking for Claude Code updates..."
    /data/home/.local/bin/claude update 2>&1 \
        || bashio::log.warning "Update check failed (non-critical)"
else
    export DISABLE_AUTOUPDATER=1
    bashio::log.info "Auto-update disabled"
fi

# --- User environment variables (KEY=VALUE, one per entry) ---
while IFS= read -r env_entry; do
    [ -n "${env_entry}" ] || continue
    key="${env_entry%%=*}"
    val="${env_entry#*=}"
    if [ -n "${key}" ] && [ "${key}" != "${env_entry}" ]; then
        export "${key}=${val}"
        bashio::log.info "Custom env: ${key}"
    else
        bashio::log.warning "Ignoring malformed environment_vars entry (expected KEY=VALUE): ${env_entry}"
    fi
done < <(bashio::config 'environment_vars')

# --- Working directory and CLAUDE.md ---
mkdir -p /data/workdir /data/uploads
mkdir -p /data/home/.claude/skills

# --- Rich status line in the embedded Claude TUI ---
# Point Claude at our bundled status line script. Seeded only when absent so a
# user who later customises .statusLine is never overwritten; script upgrades
# ship transparently because settings.json only stores the command path.
settings_file=/data/home/.claude/settings.json
[ -f "${settings_file}" ] || echo '{}' > "${settings_file}"
if [ -z "$(jq -r '.statusLine // empty' "${settings_file}" 2>/dev/null)" ]; then
    tmp_settings="$(mktemp)"
    if jq '.statusLine = {type: "command", command: "/usr/local/bin/cc-statusline", padding: 0}' \
          "${settings_file}" > "${tmp_settings}" 2>/dev/null; then
        mv "${tmp_settings}" "${settings_file}"
        bashio::log.info "Status line configured"
    else
        rm -f "${tmp_settings}"
    fi
fi

cp /usr/share/claude-ha/CLAUDE.md /data/workdir/CLAUDE.md

custom=$(bashio::config 'custom_instructions')
if bashio::var.has_value "${custom}"; then
    printf "\n\n---\n\n# User Custom Instructions\n\n%s\n" "${custom}" \
        >> /data/workdir/CLAUDE.md
fi

if [ -d /homeassistant ] && [ -w /homeassistant ] && [ ! -f /homeassistant/CLAUDE.md ]; then
    cp /data/workdir/CLAUDE.md /homeassistant/CLAUDE.md
fi

# --- Init commands ---
# Only the first word is logged — init commands may embed credentials.
while IFS= read -r cmd; do
    [ -n "${cmd}" ] || continue
    bashio::log.info "Running init command: ${cmd%% *} ..."
    eval "${cmd}" 2>&1 \
        || bashio::log.warning "Init command failed: ${cmd%% *}"
done < <(bashio::config 'init_commands')

# --- Provision bundled + user-declared extras (skills, plugins, MCP) ---
# Runs in the background so it never delays the console. Idempotent: only
# missing pieces install, and it persists in /data across restarts/updates.
{
    CC_USER_MARKETPLACES="$(jq -r '(.marketplaces // [])[]' /data/options.json 2>/dev/null)" \
    CC_USER_PLUGINS="$(jq -r '(.plugins // [])[]' /data/options.json 2>/dev/null)" \
    CC_SKILLS_GIT="$(jq -r '.skills_git // ""' /data/options.json 2>/dev/null)" \
    HA_TOKEN="${HA_TOKEN:-}" HA_URL="${HA_URL}" \
    /usr/local/bin/provision-extras
} >/data/provision.log 2>&1 &

bashio::log.info "Initialization complete (provisioning extras in background — see /data/provision.log)"

# ==============================
# Phase 2: Start web console
# ==============================

# Set AFTER user environment_vars: these are authoritative and must not be
# overridable from the config (CLAUDE_CONSOLE_DEV would disable the IP guard).
# Read straight from options.json — independent of bashio internals.
export CLAUDE_CONSOLE_PORT=8099
export CLAUDE_CONSOLE_DEV=0
export UPLOAD_DIR=/data/uploads
export UPLOAD_RETENTION_DAYS=$(jq -r '.upload_retention_days // 14' /data/options.json 2>/dev/null || echo 14)
export REMOTE_CONTROL=$(jq -r '.remote_control // false' /data/options.json 2>/dev/null || echo false)

bashio::log.info "Starting Claude Console on port ${CLAUDE_CONSOLE_PORT}..."
exec node /opt/claude-console/server/index.js
