#!/command/with-contenv bashio
# ==============================================================================
# claude-code: single longrun service
# Phase 1: initialization (persistent HOME, API key, env, CLAUDE.md)
# Phase 2: exec ttyd → tmux → claude
# ==============================================================================

# ==============================
# Phase 1: Initialization
# ==============================

bashio::log.info "Initializing Claude Code add-on..."

# --- Persistent HOME ---
# Claude Code binary is installed to /root/.local at build time.
# Copy to /data/home/.local so updates and config persist across restarts.
if [ ! -d /data/home/.local ]; then
    bashio::log.info "First run — setting up persistent home directory..."
    mkdir -p /data/home
    cp -a /root/.local /data/home/.local
fi

export HOME=/data/home
export PATH="/data/home/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export TERM=xterm-256color
export LANG=C.UTF-8
export USE_BUILTIN_RIPGREP=0

# Tell Claude Code we're running inside a container sandbox.
# Without this, --dangerously-skip-permissions is refused when the process
# runs as root (recent Claude Code versions added this safety check).
# HA add-ons always run as root inside an isolated Docker container,
# which is already a sandbox from the host's perspective.
export IS_SANDBOX=1

# --- Sync Claude binary from image if newer ---
# When the add-on image is rebuilt with a newer bundled Claude version,
# the persistent copy in /data/home/.local would otherwise stay on the
# older version until `claude update` runs. This ensures image upgrades
# actually deliver the newer binary.
sync_claude_from_image() {
    local image_bin="/root/.local/bin/claude"
    local persistent_bin="/data/home/.local/bin/claude"

    [ -x "${image_bin}" ] || return 0
    [ -x "${persistent_bin}" ] || return 0

    local image_v persistent_v newer
    image_v=$("${image_bin}" --version 2>/dev/null | awk '{print $1}') || image_v=""
    persistent_v=$("${persistent_bin}" --version 2>/dev/null | awk '{print $1}') || persistent_v=""

    if [ -z "${image_v}" ] || [ -z "${persistent_v}" ]; then
        bashio::log.warning "Could not determine Claude version for binary sync"
        return 0
    fi

    if [ "${image_v}" = "${persistent_v}" ]; then
        bashio::log.info "Claude Code version: ${persistent_v}"
        return 0
    fi

    newer=$(printf '%s\n%s\n' "${image_v}" "${persistent_v}" | sort -V | tail -n1)

    if [ "${newer}" = "${image_v}" ]; then
        bashio::log.info "Image has newer Claude (${image_v} > ${persistent_v}) — syncing to persistent storage"
        cp -af "${image_bin}" "${persistent_bin}"
        # Also refresh any supporting files the installer may have placed alongside.
        if [ -d /root/.local/share/claude ]; then
            mkdir -p /data/home/.local/share
            cp -af /root/.local/share/claude /data/home/.local/share/
        fi
    else
        bashio::log.info "Persistent Claude (${persistent_v}) is newer than image (${image_v}) — keeping persistent"
    fi
}

sync_claude_from_image

# --- Authentication ---
# Three ways to authenticate (in order of precedence Claude Code uses):
#   1. ANTHROPIC_API_KEY       — direct API key from console.anthropic.com
#   2. CLAUDE_CODE_OAUTH_TOKEN — long-lived OAuth token from `claude setup-token`
#      (run once on any machine with a browser, valid ~1 year)
#   3. Interactive `claude auth login` in the terminal (least convenient here
#      because pasting into the HA ingress iframe can be tricky).
api_key=$(bashio::config 'api_key')
oauth_token=$(bashio::config 'oauth_token')

if bashio::var.has_value "${api_key}"; then
    export ANTHROPIC_API_KEY="${api_key}"
    bashio::log.info "Anthropic API key configured"
fi

if bashio::var.has_value "${oauth_token}"; then
    export CLAUDE_CODE_OAUTH_TOKEN="${oauth_token}"
    bashio::log.info "CLAUDE_CODE_OAUTH_TOKEN configured"
fi

if ! bashio::var.has_value "${api_key}" && ! bashio::var.has_value "${oauth_token}"; then
    bashio::log.warning "No api_key or oauth_token set — run 'claude' and follow the browser login, or generate a token with 'claude setup-token' on another machine"
fi

# --- Model override ---
model=$(bashio::config 'model')
if bashio::var.has_value "${model}"; then
    export ANTHROPIC_MODEL="${model}"
    bashio::log.info "Model override: ${model}"
fi

# --- Auto-update ---
if bashio::config.true 'auto_update'; then
    bashio::log.info "Checking for Claude Code updates..."
    /data/home/.local/bin/claude update 2>&1 \
        || bashio::log.warning "Update check failed (non-critical)"
else
    export DISABLE_AUTOUPDATER=1
    bashio::log.info "Auto-update disabled"
fi

# --- User environment variables (KEY=VALUE) ---
for env_entry in $(bashio::config 'environment_vars'); do
    key="${env_entry%%=*}"
    val="${env_entry#*=}"
    if [ -n "${key}" ]; then
        export "${key}=${val}"
        bashio::log.info "Custom env: ${key}"
    fi
done

# --- Working directory and CLAUDE.md ---
mkdir -p /data/workdir
mkdir -p /data/home/.claude/skills

cp /usr/share/claude-ha/CLAUDE.md /data/workdir/CLAUDE.md

custom=$(bashio::config 'custom_instructions')
if bashio::var.has_value "${custom}"; then
    printf "\n\n---\n\n# User Custom Instructions\n\n%s\n" "${custom}" \
        >> /data/workdir/CLAUDE.md
fi

# Copy CLAUDE.md to /homeassistant if mounted and not already present
if [ -d /homeassistant ] && [ -w /homeassistant ]; then
    if [ ! -f /homeassistant/CLAUDE.md ]; then
        cp /data/workdir/CLAUDE.md /homeassistant/CLAUDE.md
    fi
fi

# --- Init commands ---
for cmd in $(bashio::config 'init_commands'); do
    bashio::log.info "Running init command: ${cmd}"
    eval "${cmd}" 2>&1 \
        || bashio::log.warning "Init command failed: ${cmd}"
done

bashio::log.info "Initialization complete"

# ==============================
# Phase 2: Start ttyd
# ==============================

declare ingress_port
ingress_port=$(bashio::addon.ingress_port)

bashio::log.info "Starting ttyd web terminal on port ${ingress_port}..."

# Prefer /homeassistant as working dir
if [ -d /homeassistant ] && [ -w /homeassistant ]; then
    cd /homeassistant
else
    cd /data/workdir
fi

# ttyd options kept minimal — the combo below matches the config that was
# known-working in v0.1.x. Extra `-t` flags I added in v0.2.1 (copyOnSelect,
# rightClickSelectsWord, macOptionIsMeta, cursorBlink) turned out to either
# be no-ops (copyOnSelect is not an actual ttyd/xterm.js option) or to
# interact badly with HA's ingress-iframe clipboard behavior. Sticking to
# the minimal v0.1.x set restores working copy/paste in the sidebar.
exec ttyd \
    --port "${ingress_port}" \
    --writable \
    --ping-interval 30 \
    -t fontSize=14 \
    -t rendererType=webgl \
    -t disableLeaveAlert=true \
    tmux -u new -A -s claude /usr/local/bin/start-claude
