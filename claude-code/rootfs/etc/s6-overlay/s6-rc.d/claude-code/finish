#!/usr/bin/env bashio
# ==============================================================================
# claude-code finish: halt add-on on unexpected exit
# ==============================================================================
declare EXIT_CODE=${1}

if [[ "${EXIT_CODE}" -ne 0 ]] && [[ "${EXIT_CODE}" -ne 256 ]]; then
    bashio::log.error "Service exited unexpectedly (code: ${EXIT_CODE}) — stopping add-on"
    echo "${EXIT_CODE}" > /run/s6-linux-init-container-results/exitcode
    exec /run/s6/basedir/bin/halt
fi
