#!/usr/bin/bashio
# ==============================================================================
# start-claude: runs inside the "claude" tmux window.
# Launches Claude Code with configured flags; on exit shows a small menu so
# the session survives (restart / shell / update) instead of dying.
# Deliberately s6-independent (no with-contenv): it only needs
# /data/options.json, so it works identically under s6, tmux respawn,
# a shell tab, or a bare container.
# ==============================================================================

# Pin HOME to persistent storage — auth tokens and sessions must never land
# in the ephemeral /root.
export HOME=/data/home
export PATH="/data/home/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# Working directory: prefer HA config, fall back to add-on storage
if [ -d /homeassistant ] && [ -w /homeassistant ]; then
    cd /homeassistant
else
    cd /data/workdir
fi

# Does this Claude version still accept --dangerously-skip-permissions under our
# (root) user? It normally does because the add-on exports IS_SANDBOX=1, but that
# is an undocumented escape hatch a future CLI could drop. Pre-flight it with a
# credential-free HOME (so no API call happens) and detect the root guard.
skip_permissions_supported() {
    local out
    out=$(env -u ANTHROPIC_API_KEY -u CLAUDE_CODE_OAUTH_TOKEN -u ANTHROPIC_AUTH_TOKEN \
            HOME=/tmp/cc-skipcheck timeout 25 \
            claude --dangerously-skip-permissions -p . 2>&1 </dev/null || true)
    rm -rf /tmp/cc-skipcheck 2>/dev/null
    ! grep -qi 'root/sudo' <<<"${out}"
}

build_default_args() {
    claude_args=()
    if bashio::config.true 'bypass_permissions'; then
        if skip_permissions_supported; then
            claude_args+=(--dangerously-skip-permissions)
        else
            bashio::log.warning "Skip-permissions is enabled but this Claude version rejects it under root — launching WITHOUT it (Claude will ask for confirmations)."
            cat << 'EOF'

  ⚠  "Skip Permission Prompts" is on, but this Claude Code version no longer
     allows it under the add-on's root user. Claude will ask for confirmation
     as usual. To restore autonomous mode, update the add-on, or pin a version
     that supports it from a shell tab:  update-claude <version>

EOF
        fi
    fi
    while IFS= read -r arg; do
        [ -n "${arg}" ] && claude_args+=("${arg}")
    done < <(bashio::config 'extra_args')
}

run_claude() {
    local launch_command
    launch_command=$(bashio::config 'launch_command')
    if bashio::var.has_value "${launch_command}"; then
        bash -c "${launch_command}"
    else
        local claude_args
        build_default_args
        claude "${claude_args[@]}"
    fi
}

show_menu() {
    local v
    v=$(claude --version 2>/dev/null | awk '{print $1}')
    echo ""
    echo "Claude exited. [Claude Code ${v:-unknown}]"
    echo "  r) restart Claude          s) drop to shell"
    echo "  u) update Claude, restart  c) resume last conversation"
    echo ""
    read -r -n 1 -p "> " choice
    echo ""
    case "${choice}" in
        s|S) bash ;;
        u|U) update-claude && run_claude ;;
        c|C) claude --continue ;;
        *)   : ;;
    esac
}

while true; do
    run_claude
    show_menu
done
