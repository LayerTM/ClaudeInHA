#!/command/with-contenv bashio
# ==============================================================================
# start-claude: runs inside the "claude" tmux window.
# Launches Claude Code with configured flags; on exit shows a small menu so
# the session survives (restart / shell / update) instead of dying.
# ==============================================================================

# Pin HOME to persistent storage: with-contenv may bring HOME=/root from the
# container environment, which would send auth tokens and sessions to an
# ephemeral location.
export HOME=/data/home
export PATH="/data/home/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# Working directory: prefer HA config, fall back to add-on storage
if [ -d /homeassistant ] && [ -w /homeassistant ]; then
    cd /homeassistant
else
    cd /data/workdir
fi

build_default_args() {
    claude_args=()
    if bashio::config.true 'bypass_permissions'; then
        claude_args+=(--dangerously-skip-permissions)
    fi
    while IFS= read -r arg; do
        [ -n "${arg}" ] && claude_args+=("${arg}")
    done < <(bashio::config 'extra_args')
}

run_claude() {
    local launch_command
    launch_command=$(bashio::config 'launch_command')
    if bashio::var.has_value "${launch_command}"; then
        bash -c "${launch_command}"
    else
        local claude_args
        build_default_args
        claude "${claude_args[@]}"
    fi
}

show_menu() {
    local v
    v=$(claude --version 2>/dev/null | awk '{print $1}')
    echo ""
    echo "Claude exited. [Claude Code ${v:-unknown}]"
    echo "  r) restart Claude          s) drop to shell"
    echo "  u) update Claude, restart  c) resume last conversation"
    echo ""
    read -r -n 1 -p "> " choice
    echo ""
    case "${choice}" in
        s|S) bash ;;
        u|U) update-claude && run_claude ;;
        c|C) claude --continue ;;
        *)   : ;;
    esac
}

while true; do
    run_claude
    show_menu
done
