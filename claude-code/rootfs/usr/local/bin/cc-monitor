#!/usr/bin/env bash
# Proactive monitoring loop (opt-in). Every CLAUDE_MONITOR_HOURS hours, ask
# Claude to review the HA error log + config and, only if something notable is
# found, push a short summary via ha-notify. Started by the service when the
# add-on's `monitoring_interval_hours` option is > 0. Requires Claude to be
# logged in, and it spends plan usage on each run — hence opt-in.
set -o pipefail
export HOME=/data/home
export PATH="/data/home/.local/bin:/usr/local/bin:/usr/bin:/bin"

hours="${CLAUDE_MONITOR_HOURS:-0}"
[ "${hours}" -gt 0 ] 2>/dev/null || exit 0

read -r -d '' PROMPT <<'EOF'
Proactively review this Home Assistant instance for problems the user should
know about. Check the error log:
  curl -sS -H "Authorization: Bearer $SUPERVISOR_TOKEN" http://supervisor/core/api/error_log
and validate the configuration with `ha-check`. If you find something worth
flagging (errors, failing/unavailable integrations, invalid config, anything
broken), reply with ONE short plain-text paragraph the user can read on their
phone. If everything looks healthy, reply with exactly: OK
EOF

sleep 120  # let the console and login settle after boot

while true; do
    out="$(claude -p --dangerously-skip-permissions "${PROMPT}" 2>/dev/null | tail -c 1500)"
    trimmed="$(printf '%s' "${out}" | tr -d '[:space:]')"
    if [ -n "${trimmed}" ] && [ "${trimmed}" != "OK" ]; then
        ha-notify "${out}" "Claude · HA health check" >/dev/null 2>&1 || true
    fi
    sleep "$(( hours * 3600 ))"
done
