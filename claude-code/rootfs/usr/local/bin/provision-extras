#!/usr/bin/env bash
# ==============================================================================
# provision-extras: reconcile the bundled + user-declared Claude Code extras
# into the persistent HOME (/data/home). Idempotent — safe to run every start;
# only missing pieces are installed. Run in the background by the service so it
# never blocks the console. Logs to /data/provision.log.
# ==============================================================================
export HOME=/data/home
export PATH="/data/home/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

log() { echo "[$(date '+%H:%M:%S')] $*"; }

# Single-instance lock: never run two reconciles at once (they write the same
# ~/.claude files). A concurrent start just skips — the running one covers it.
mkdir -p /data/home/.claude
exec 9>/data/home/.claude/.provision.lock
if ! flock -n 9; then
    log "provisioning already running — skipping"
    exit 0
fi

# --- 1. Bundled HA skill pack ---
# These skills are add-on-owned: overwrite so image updates propagate. User's
# own skills (any other name, or from skills_git) are never touched.
mkdir -p /data/home/.claude/skills
if [ -d /opt/ha-skills ]; then
    cp -rf /opt/ha-skills/. /data/home/.claude/skills/ 2>/dev/null || true
    log "HA skill pack synced to ~/.claude/skills"
fi

# --- 2. Marketplaces + plugins (base + user config) ---
BASE_MARKETPLACES=(anthropics/claude-plugins-official anthropics/skills)
BASE_PLUGINS=(
    superpowers@claude-plugins-official
    frontend-design@claude-plugins-official
    skill-creator@claude-plugins-official
    security-guidance@claude-plugins-official
    context7@claude-plugins-official
    code-review@claude-plugins-official
    code-simplifier@claude-plugins-official
    feature-dev@claude-plugins-official
    commit-commands@claude-plugins-official
    claude-md-management@claude-plugins-official
    hookify@claude-plugins-official
    document-skills@anthropic-agent-skills
)

# User additions (newline-separated env from the service)
mapfile -t USER_MARKETPLACES < <(printf '%s\n' "${CC_USER_MARKETPLACES:-}" | sed '/^$/d')
mapfile -t USER_PLUGINS < <(printf '%s\n' "${CC_USER_PLUGINS:-}" | sed '/^$/d')

installed_marketplaces="$(claude plugin marketplace list 2>/dev/null || true)"
for mp in "${BASE_MARKETPLACES[@]}" "${USER_MARKETPLACES[@]}"; do
    [ -n "${mp}" ] || continue
    # Match the source in parentheses ("… (owner/repo)" / "… (https://…)") so a
    # slug that is a substring of another marketplace's does not false-match.
    if ! grep -qF "(${mp})" <<<"${installed_marketplaces}"; then
        log "adding marketplace ${mp}"
        claude plugin marketplace add "${mp}" >/dev/null 2>&1 \
            && log "  ok ${mp}" || log "  FAILED ${mp} (will retry next start)"
    fi
done

installed_plugins="$(claude plugin list 2>/dev/null || true)"
for pl in "${BASE_PLUGINS[@]}" "${USER_PLUGINS[@]}"; do
    [ -n "${pl}" ] || continue
    name="${pl%@*}"
    if ! grep -qE "^\s*❯?\s*${name}@" <<<"${installed_plugins}"; then
        log "installing plugin ${pl}"
        claude plugin install "${pl}" >/dev/null 2>&1 \
            && log "  ok ${pl}" || log "  FAILED ${pl} (will retry next start)"
    fi
done

# --- 3. Personal skills repo (optional) ---
# skills_git repo layout: each top-level dir is a skill containing SKILL.md.
if [ -n "${CC_SKILLS_GIT:-}" ]; then
    cache=/data/home/.claude/.skills-git
    if [ -d "${cache}/.git" ]; then
        git -C "${cache}" pull --ff-only >/dev/null 2>&1 && log "skills_git pulled" \
            || log "skills_git pull failed"
    else
        rm -rf "${cache}"
        git clone --depth 1 "${CC_SKILLS_GIT}" "${cache}" >/dev/null 2>&1 \
            && log "skills_git cloned" || log "skills_git clone failed"
    fi
    if [ -d "${cache}" ]; then
        for d in "${cache}"/*/; do
            [ -f "${d}SKILL.md" ] || continue
            name="$(basename "${d}")"
            # Mirror (not overlay) so skills deleted upstream don't linger.
            rm -rf "/data/home/.claude/skills/${name}"
            cp -r "${d}" /data/home/.claude/skills/ 2>/dev/null
        done
        log "skills_git skills synced"
    fi
fi

# --- 4. MCP servers (user scope; avoids project workspace-trust prompt) ---
mcp_has() { claude mcp list 2>/dev/null | grep -qE "(^|\s)${1}(\s|:|$)"; }

if ! mcp_has playwright; then
    log "registering playwright MCP"
    claude mcp add playwright -s user -- \
        playwright-mcp --headless --no-sandbox \
        --browser chromium --executable-path /usr/bin/chromium >/dev/null 2>&1 \
        && log "  ok playwright" || log "  FAILED playwright MCP"
fi

if [ -n "${HA_TOKEN:-}" ]; then
    if ! mcp_has hass-mcp; then
        log "registering hass-mcp (HA Token present)"
        claude mcp add hass-mcp -s user \
            -e "HA_URL=${HA_URL:-http://homeassistant:8123}" \
            -e "HA_TOKEN=${HA_TOKEN}" -- hass-mcp >/dev/null 2>&1 \
            && log "  ok hass-mcp" || log "  FAILED hass-mcp"
    fi
fi

log "provisioning complete"
