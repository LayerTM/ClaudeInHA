{
  "name": "claude-console",
  "version": "1.0.0",
  "private": true,
  "description": "Web console serving the Claude Code CLI for the Home Assistant add-on",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "test": "node --test \"test/**/*.test.js\"",
    "test:alerts": "bash test/cc-alerts.test.sh",
    "lint": "eslint .",
    "typecheck": "tsc -p jsconfig.json"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "busboy": "1.6.0",
    "express": "5.2.1",
    "node-pty": "1.1.0",
    "ws": "8.21.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/busboy": "1.5.4",
    "@types/express": "5.0.6",
    "@types/node": "22.20.1",
    "@types/ws": "8.18.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "typescript": "7.0.2"
  }
}
